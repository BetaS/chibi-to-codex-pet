{
  "name": "livesd-pet-builder",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm verify:repository-boundary && tsc -b && pnpm verify:provider-harness && pnpm --filter chibi-to-codex-pet build && pnpm --filter chibi-to-codex-pet verify:pack && pnpm verify:runtime && pnpm verify:garupa-manifest && vite build && pnpm verify:dist",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && pnpm --filter chibi-to-codex-pet typecheck",
    "lint": "eslint .",
    "test": "vitest run && pnpm --filter chibi-to-codex-pet test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test --config playwright.local.config.ts",
    "verify:provider-harness": "vitest run src/features/providerIntegrationHarness.test.tsx",
    "verify:repository-boundary": "node build/verifyRepositoryBoundary.mjs",
    "verify:dist": "node build/verifyProductionArtifacts.mjs",
    "verify:garupa-manifest": "node build/verifyGarupaProviderManifest.mjs",
    "verify:runtime": "node build/verifyRuntimeProvenance.mjs"
  },
  "dependencies": {
    "@esotericsoftware/spine-webgl": "4.0.31",
    "@zip.js/zip.js": "2.8.26",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
